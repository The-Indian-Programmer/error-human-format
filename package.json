{
  "name": "error-human-format",
  "version": "1.0.0",
  "description": "Intelligent error explanation engine — converts raw JS/Node.js errors into human-readable explanations with actionable debugging suggestions",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./middleware": {
      "types": "./dist/middleware/index.d.ts",
      "import": "./dist/middleware/index.mjs",
      "require": "./dist/middleware/index.js"
    }
  },
  "bin": {
    "error-humanizer": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli/index.ts src/middleware/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test",
    "demo": "tsx demo.ts"
  },
  "keywords": [
    "error",
    "debugging",
    "developer-experience",
    "error-handling",
    "stack-trace",
    "nodejs",
    "typescript",
    "cli"
  ],
  "author": "error-humanizer contributors",
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^1.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/The-Indian-Programmer/error-human-format"
  },
  "bugs": {
    "url": "https://github.com/The-Indian-Programmer/issues"
  },
  "homepage": "https://github.com/The-Indian-Programmer/error-human-format#readme"
}
